{
  "name": "eda-document-analyzer",
  "version": "0.1.0",
  "private": false,
  "scripts": {
    "dev": "next dev --turbopack",
    "dev-no-turbo": "next dev",
    "build": "next build",
    "build:static": "next build",
    "start": "next start",
    "lint": "biome check",
    "format": "biome format --write",
    "test": "vitest",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{js,ts,cjs,mjs,d.cts,d.mts,jsx,tsx,json,jsonc}": [
      "biome check --files-ignore-unknown=true --no-errors-on-unmatched"
    ]
  },
  "dependencies": {
    "@tailwindcss/postcss": "4.3.3",
    "lucide-react": "1.26.0",
    "next": "16.2.11",
    "postcss": "8.5.23",
    "react": "19.2.8",
    "react-dom": "19.2.8",
    "react-hot-toast": "2.6.0",
    "tailwindcss": "4.3.3",
    "uuid": "14.0.1"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.5",
    "@playwright/test": "1.61.1",
    "@testing-library/dom": "10.4.1",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@testing-library/user-event": "14.6.1",
    "@types/node": "25.9.5",
    "@types/react": "19.2.17",
    "@vitejs/plugin-react": "6.0.4",
    "@vitest/coverage-v8": "4.1.10",
    "husky": "9.1.7",
    "jsdom": "29.1.1",
    "lint-staged": "17.2.0",
    "typescript": "6.0.3",
    "vitest": "4.1.10"
  }
}
